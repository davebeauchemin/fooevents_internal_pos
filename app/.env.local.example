# Copy to .env.local and fill in. Never commit .env.local.
# Local Vite dev: calls go to the same host (e.g. localhost:5173/wp-json) and
# the Vite proxy forwards to the live site with an Application Password.

# Same-origin path the browser uses (Vite dev server); proxy rewrites to VITE_WP_REMOTE
VITE_WORDPRESS_URL=/wp-json/

# React Router base when running the Vite dev entry (served at /)
VITE_APP_BASENAME=/

# Live WordPress site (no trailing slash)
VITE_WP_REMOTE=https://example.com
VITE_WP_APP_USER=your-wp-username
# Paste the application password (spaces in the middle are OK)
VITE_WP_APP_PASS=xxxx xxxx xxxx xxxx xxxx xxxx
